# TaxFlow Pro Environment Configuration
# Copy this to .env and fill in your values. NEVER commit .env.

# Security (REQUIRED in production)
TAXFLOW_SECRET_KEY=your-random-secret-here-min-32-chars

# Database
DATABASE_URL=sqlite:///./taxflow.db
# DATABASE_URL=postgresql://user:pass@localhost:5432/taxflow

# API
API_HOST=0.0.0.0
API_PORT=8000

# Frontend
FRONTEND_URL=http://localhost:3000

# Upload
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=uploads

# OCR (optional)
TESSERACT_CMD=/usr/bin/tesseract
POPPLER_PATH=/usr/bin
