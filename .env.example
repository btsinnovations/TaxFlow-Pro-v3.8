# TaxFlow Pro v3.8 - Environment Template
# Copy this file to .env and fill in your values. NEVER commit .env.

# ---------------------------------------------------------------------------
# Security (REQUIRED)
# ---------------------------------------------------------------------------
TAXFLOW_SECRET_KEY=242a1ec0e418c83e5cd732abd4e1ec27d2ee684251250d25fcf21c0ebaa8f66c

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Default: SQLite for local development. Uncomment PostgreSQL line for production.
DATABASE_URL=sqlite:///./taxflow.db
# DATABASE_URL=postgresql://user:password@localhost:5432/taxflow

# ---------------------------------------------------------------------------
# API Server
# ---------------------------------------------------------------------------
API_HOST=0.0.0.0
API_PORT=8000

# ---------------------------------------------------------------------------
# Frontend (Vite / React)
# ---------------------------------------------------------------------------
FRONTEND_URL=http://localhost:3000
VITE_API_BASE_URL=http://localhost:8000/api

# ---------------------------------------------------------------------------
# Upload
# ---------------------------------------------------------------------------
MAX_UPLOAD_SIZE_MB=50
UPLOAD_DIR=uploads

# ---------------------------------------------------------------------------
# OCR (optional - set if tesseract/poppler not in PATH)
# ---------------------------------------------------------------------------
# TESSERACT_CMD=/usr/bin/tesseract
# POPPLER_PATH=/usr/bin
