# TaxFlow Pro v3.7 — Environment Template
# Copy this file to `.env` and fill in your values.

# ---------------------------------------------------------------------------
# Secret file (TASK-036)
# ---------------------------------------------------------------------------
# Path to a key=value secrets file kept outside version control. Values in
# this file override environment variables for DATABASE_URL, SQLCipher
# passwords, and other sensitive settings.
# Example line format:
#   DATABASE_URL=postgresql://user:password@localhost:5432/taxflow
#   TAXFLOW_DB_PASSWORD=my-secret-sqlcipher-password
# TAXFLOW_SECRETS_FILE=.secrets

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# Default: SQLite for local development. Uncomment PostgreSQL line for production.
DATABASE_URL=sqlite:///./taxflow.db
# DATABASE_URL=postgresql://user:password@localhost:5432/taxflow

# ---------------------------------------------------------------------------
# SQLCipher (TASK-038 / 3.3)
# ---------------------------------------------------------------------------
# Master password for SQLCipher-encrypted SQLite databases. Required when
# DATABASE_URL starts with sqlcipher:///.
TAXFLOW_DB_PASSWORD=

# Optional path to a keyfile used alongside the password for stronger key
# derivation. Keep this file outside the project directory and restrict access.
TAXFLOW_DB_KEYFILE=

# Optional keyring token for retrieving the SQLCipher password from the OS
# keyring instead of a plain env var or secrets file.
TAXFLOW_DB_KEYRING_TOKEN=

# ---------------------------------------------------------------------------
# Security headers + CORS hardening (TASK-027)
# ---------------------------------------------------------------------------
# Runtime environment: development | production. Controls HSTS and other
# production-only headers.
TAXFLOW_ENVIRONMENT=development

# Comma-separated list of origins allowed to make CORS requests. Credentials
# are only sent to these exact origins. Default local dev origins are used
# when this variable is empty or unset.
TAXFLOW_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# JWT signing key. MUST be changed for any non-local / production deployment.
TAXFLOW_SECRET_KEY=change-this-to-a-long-random-secret-in-production

# Ed25519 private key for signing audit entries. If unset, a deterministic
# fallback key is derived from the local secret (dev/test only; production
# should generate and protect a real Ed25519 key).
TAXFLOW_AUDIT_PRIVATE_KEY_PATH=

# Path to a pre-built JSON bloom filter for known breached passwords.
# If unset, a small built-in default wordlist is used (not suitable for production).
TAXFLOW_BREACH_BLOOM_PATH=

# ---------------------------------------------------------------------------
# Global rate limiting (TASK-028)
# ---------------------------------------------------------------------------
# Format: N/UNIT or N/MULTIPLIER UNIT, where UNIT is second, minute, hour, day.
# Default: 100/minute. Burst allows the first N requests through unconditionally.
TAXFLOW_GLOBAL_RATE_LIMIT=100/minute
TAXFLOW_GLOBAL_BURST_LIMIT=10

# Number of trusted proxy hops in front of the app. If >0, the client IP is
# taken from X-Forwarded-For. Set to 0 (default) to ignore the header and use
# the direct remote address, preventing spoofing.
TAXFLOW_TRUSTED_PROXY_HOPS=0

# ---------------------------------------------------------------------------
# Request size limits (TASK-031)
# ---------------------------------------------------------------------------
# General request body limit in bytes (JSON, form, etc.), not multipart uploads.
# Default: 10 MiB (10485760). Uploads to /api/upload use TAXFLOW_MAX_UPLOAD_BYTES.
TAXFLOW_MAX_BODY_SIZE_BYTES=10485760

# ---------------------------------------------------------------------------
# JWT access token lifetime in minutes (default: 15).
TAXFLOW_TOKEN_EXPIRE_MINUTES=15

# JWT refresh token lifetime in days (default: 30).
TAXFLOW_REFRESH_TOKEN_EXPIRE_DAYS=30

# ---------------------------------------------------------------------------
# Upload
# ---------------------------------------------------------------------------
# Maximum upload size in bytes (default: 32 MiB).
TAXFLOW_MAX_UPLOAD_BYTES=33554432

# If true, require PDF magic header to declare version 1.x or 2.x.
TAXFLOW_UPLOAD_MAGIC_STRICT=false
# ---------------------------------------------------------------------------
# Parser sandbox
# ---------------------------------------------------------------------------
# Subprocess PDF parser defaults. The upload router uses these values.
TAXFLOW_PARSER_TIMEOUT_SECONDS=30
TAXFLOW_PARSER_MAX_MEMORY_MB=512

# ---------------------------------------------------------------------------
# Vulnerability scanning
# ---------------------------------------------------------------------------
# Path to a local, offline vulnerability database (JSON, OSV-style or flat list).
# Default: data/vuln-db.json
TAXFLOW_VULN_DB_PATH=data/vuln-db.json

# ---------------------------------------------------------------------------
# Secret scanning
# ---------------------------------------------------------------------------
# Comma-separated list of patterns to reject in staged/new files when running
# the pre-commit secret scanner. Supports shell-style wildcards.
TAXFLOW_SECRET_PATTERNS=password,secret,key,token,api_key,apikey,private_key,client_secret,aws_access_key_id

# If true, fail pre-commit when a potential secret is detected.
TAXFLOW_SECRET_SCAN_FAIL=true

# ---------------------------------------------------------------------------
# Base URL the React frontend uses to reach the FastAPI backend.
VITE_API_BASE_URL=http://localhost:8000/api

# ---------------------------------------------------------------------------
# Path traversal protection (TASK-033)
# ---------------------------------------------------------------------------
# Directory for file-based exports. All export files are constrained to this
# path under the project root. Defaults to 'exports/'.
TAXFLOW_EXPORT_DIR=exports

