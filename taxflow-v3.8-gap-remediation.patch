+        { id: "json", name: "JSON", description: "Structured data export", icon: "Database", color: "#9333ea", status: "available" },
+        { id: "drake", name: "Drake Tax", description: "Drake Tax Software import", icon: "Download", color: "#dc2626", status: "available" },
+        { id: "lacerte", name: "Lacerte", description: "Intuit Lacerte Tax import", icon: "Download", color: "#ea580c", status: "available" },
+      ]))
+      .finally(() => setLoading(false));
