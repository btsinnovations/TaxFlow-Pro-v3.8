+import httpx
+from datetime import datetime
+
+try:
+    from ofxparse import OfxParser
+except ImportError:
+    OfxParser = None  # type: ignore
+
+
+class OFXClient:
+    def __init__(self, fi_org: str, fi_url: str, user_id: str, password: str):
+        self.fi_org = fi_org
+        self.fi_url = fi_url
+        self.user_id = user_id
+        self.password = password
+
+    def _build_ofx_request(self, start_date: datetime, end_date: datetime) -> str:
+        dtnow = datetime.now().strftime("%Y%m%d%H%M%S")
+        dtstart = start_date.strftime("%Y%m%d%H%M%S")
+        dtend = end_date.strftime("%Y%m%d%H%M%S")
+
+        ofx = f"""OFXHEADER:100
+DATA:OFXSGML
+VERSION:102
+SECURITY:NONE
+ENCODING:USASCII
+CHARSET:1252
+COMPRESSION:NONE
+OLDFILEUID:NONE
+NEWFILEUID:{dtnow}
+
+<OFX>
+<SIGNONMSGSRQV1>
+<SONRQ>
+<DTCLIENT>{dtnow}</DTCLIENT>
+<USERID>{self.user_id}</USERID>
+<USERPASS>{self.password}</USERPASS>
+<LANGUAGE>ENG</LANGUAGE>
+<FI>
+<ORG>{self.fi_org}</ORG>
+</FI>
+<APPID>QWIN</APPID>
+<APPVER>2700</APPVER>
+</SONRQ>
+</SIGNONMSGSRQV1>
+<BANKMSGSRQV1>
+<STMTTRNRQ>
+<TRNUID>{dtnow}</TRNUID>
+<STMTRQ>
+<BANKACCTFROM>
+<ACCTID>{self.user_id}</ACCTID>
+<ACCTTYPE>CHECKING</ACCTTYPE>
+</BANKACCTFROM>
+<INCTRAN>
+<DTSTART>{dtstart}</DTSTART>
+<DTEND>{dtend}</DTEND>
+<INCLUDE>Y</INCLUDE>
+</INCTRAN>
+</STMTRQ>
+</STMTTRNRQ>
+</BANKMSGSRQV1>
+</OFX>"""
+        return ofx
+
+    async def fetch_transactions(self, start_date: datetime, end_date: datetime):
+        if OfxParser is None:
+            raise RuntimeError(
+                "ofxparse is required for OFX parsing. "
+                "Install it with: pip install ofxparse"
+            )
+        ofx_data = self._build_ofx_request(start_date, end_date)
+        async with httpx.AsyncClient() as client:
+            response = await client.post(
+                self.fi_url,
+                content=ofx_data,
+                headers={"Content-Type": "application/x-ofx"}
+            )
+            response.raise_for_status()
+            return OfxParser.parse(response.content)
