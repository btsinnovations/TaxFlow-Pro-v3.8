+import type { AuditEvent } from "@/types";
+
+export default function Audit() {
+  const { get } = useApi();
+  const [events, setEvents] = useState<AuditEvent[]>([]);
+  const [loading, setLoading] = useState(true);
+
+  useEffect(() => {
+    get(API.audit)
+      .then((data: any) => setEvents(data.events ?? []))
+      .catch(() => setEvents([]))
+      .finally(() => setLoading(false));
+  }, [get]);
+
+  return (
+    <div className="space-y-4">
+      <div>
+        <h1 className="text-2xl font-bold tracking-tight">Audit Trail</h1>
+        <p className="text-sm text-slate-500">Statement upload and processing history</p>
+      </div>
+
+      <Card>
+        <CardContent className="p-0">
+          {loading ? (
+            <div className="p-4 space-y-3"><Skeleton className="h-8" /><Skeleton className="h-8" /></div>
+          ) : events.length === 0 ? (
+            <div className="flex flex-col items-center justify-center py-12 text-slate-400">
+              <ClipboardList className="h-10 w-10 mb-3" />
+              <p>No audit events yet</p>
+              <p className="text-xs mt-1">Events appear when statements are uploaded</p>
+            </div>
+          ) : (
+            <Table>
+              <TableHeader>
+                <TableRow>
+                  <TableHead>Event</TableHead>
+                  <TableHead>Statement</TableHead>
+                  <TableHead>Filename</TableHead>
+                  <TableHead>Balanced</TableHead>
+                  <TableHead>Variance</TableHead>
+                  <TableHead>Date</TableHead>
+                </TableRow>
+              </TableHeader>
+              <TableBody>
+                {events.map((e, i) => (
+                  <TableRow key={i}>
+                    <TableCell className="capitalize text-sm">{e.type}</TableCell>
+                    <TableCell className="font-mono text-xs">#{e.statement_id}</TableCell>
+                    <TableCell className="max-w-xs truncate text-sm">{e.filename}</TableCell>
+                    <TableCell>
+                      {e.is_balanced ? (
+                        <Badge className="bg-emerald-100 text-emerald-700 gap-1 text-xs"><CheckCircle className="h-3 w-3" /> Yes</Badge>
+                      ) : (
+                        <Badge variant="secondary" className="gap-1 text-xs"><AlertTriangle className="h-3 w-3" /> No</Badge>
+                      )}
+                    </TableCell>
+                    <TableCell className="font-mono text-sm">{e.variance !== null ? `$${Number(e.variance).toFixed(2)}` : "—"}</TableCell>
+                    <TableCell className="text-sm whitespace-nowrap">{e.created_at ? new Date(e.created_at).toLocaleString() : "—"}</TableCell>
+                  </TableRow>
+                ))}
+              </TableBody>
+            </Table>
+          )}
+        </CardContent>
+      </Card>
+    </div>
+  );
+}
