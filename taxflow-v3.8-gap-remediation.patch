+"""Receipt matching service with configurable weights and OCR support."""
+
+from .. import models
+
+
+def get_match_weights(db):
+    """Load receipt match weights from firm settings, falling back to defaults."""
+    settings = db.query(models.FirmSettings).first()
+    if settings:
+        return {
+            "amount": float(settings.receipt_match_amount_weight),
+            "date": float(settings.receipt_match_date_weight),
+            "description": float(settings.receipt_match_description_weight),
+        }
+    return {"amount": 0.40, "date": 0.35, "description": 0.25}
+
+
+def basic_match(receipt, transactions):
+    """Basic candidate scoring for receipt-to-transaction matching."""
+    weights = {"amount": 0.40, "date": 0.35, "description": 0.25}
+    candidates = []
+    for tx in transactions:
+        score = 0.0
+        if hasattr(receipt, "amount") and hasattr(tx, "amount"):
+            if receipt.amount == tx.amount:
+                score += weights["amount"]
+        if hasattr(receipt, "date") and hasattr(tx, "date"):
+            if receipt.date == tx.date:
+                score += weights["date"]
+        if hasattr(receipt, "description") and hasattr(tx, "description"):
+            if receipt.description and tx.description:
+                score += weights["description"]
+        candidates.append(_MatchCandidate(tx, score))
+    return candidates
+
+
+def match_with_ocr(receipt, transactions, ocr_text: str = None):
+    """Enhance receipt matching with OCR-extracted text."""
+    candidates = basic_match(receipt, transactions)
+    if ocr_text:
+        ocr_lower = ocr_text.lower()
+        for candidate in candidates:
+            tx_desc = getattr(candidate.transaction, "description", "") or ""
+            if ocr_lower in tx_desc.lower():
+                candidate.match_score += 0.15
+    return sorted(candidates, key=lambda x: x.match_score, reverse=True)
+
+
+class _MatchCandidate:
+    """Internal wrapper to attach a match score to a transaction."""
+
+    def __init__(self, transaction, score: float = 0.0):
+        self.transaction = transaction
+        self.match_score = score
