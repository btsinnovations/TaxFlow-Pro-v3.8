+import { Brain, Zap, TrendingUp } from "lucide-react";
+import type { MLStatus as MLStatusType } from "@/types";
+
+export default function MLStatus() {
+  const { get, post } = useApi();
+  const [status, setStatus] = useState<MLStatusType | null>(null);
+  const [loading, setLoading] = useState(true);
+  const [toggling, setToggling] = useState(false);
+
+  const fetchStatus = () => {
+    setLoading(true);
+    get(API.ml.status)
+      .then((data: MLStatusType) => setStatus(data))
+      .catch(() => setStatus({ enabled: false, model_version: null, accuracy: null, last_trained: null, training_samples: null }))
+      .finally(() => setLoading(false));
+  };
+
+  useEffect(() => { fetchStatus(); }, [get]);
+
+  const handleToggle = async () => {
+    setToggling(true);
+    try {
+      await post(API.ml.toggle);
+      fetchStatus();
+    } catch (e) { alert("Failed to toggle ML"); }
+    setToggling(false);
+  };
+
+  return (
+    <div className="space-y-6">
+      <div className="flex items-center justify-between">
+        <div>
+          <h1 className="text-2xl font-bold tracking-tight">ML Pipeline</h1>
+          <p className="text-sm text-slate-500">Machine learning categorization status</p>
+        </div>
+      </div>
+
+      {loading ? (
+        <Skeleton className="h-48 rounded-xl" />
+      ) : (
+        <div className="grid grid-cols-1 lg:grid-cols-2 gap-6">
+          <Card>
+            <CardHeader><CardTitle className="text-base flex items-center gap-2"><Brain className="h-4 w-4" /> Model Status</CardTitle></CardHeader>
+            <CardContent className="space-y-4">
+              <div className="flex items-center justify-between">
+                <span className="text-sm">ML Categorization</span>
+                <Switch checked={status?.enabled ?? false} onCheckedChange={handleToggle} disabled={toggling} />
+              </div>
+              <div className="grid grid-cols-2 gap-4 text-sm">
+                <div className="bg-slate-50 rounded-lg p-3">
+                  <p className="text-slate-500 text-xs">Status</p>
+                  <p className={`font-semibold ${status?.enabled ? "text-emerald-600" : "text-slate-400"}`}>{status?.enabled ? "Enabled" : "Disabled"}</p>
+                </div>
+                <div className="bg-slate-50 rounded-lg p-3">
+                  <p className="text-slate-500 text-xs">Model Version</p>
+                  <p className="font-semibold">{status?.model_version ?? "—"}</p>
+                </div>
+                <div className="bg-slate-50 rounded-lg p-3">
+                  <p className="text-slate-500 text-xs">Last Trained</p>
+                  <p className="font-semibold">{status?.last_trained ? new Date(status.last_trained).toLocaleDateString() : "—"}</p>
+                </div>
+                <div className="bg-slate-50 rounded-lg p-3">
+                  <p className="text-slate-500 text-xs">Training Samples</p>
+                  <p className="font-semibold">{status?.training_samples?.toLocaleString() ?? "—"}</p>
+                </div>
+              </div>
+              {status?.accuracy !== null && status?.accuracy !== undefined && (
+                <div className="space-y-1">
+                  <div className="flex justify-between text-sm">
+                    <span>Accuracy</span>
+                    <span className="font-medium">{(status.accuracy * 100).toFixed(1)}%</span>
+                  </div>
+                  <Progress value={status.accuracy * 100} className="h-2" />
+                </div>
+              )}
+            </CardContent>
+          </Card>
+
+          <Card>
+            <CardHeader><CardTitle className="text-base flex items-center gap-2"><Zap className="h-4 w-4" /> Quick Actions</CardTitle></CardHeader>
+            <CardContent className="space-y-3">
+              <Button className="w-full bg-emerald-600 hover:bg-emerald-700 gap-2" disabled={!status?.enabled}>
+                <TrendingUp className="h-4 w-4" /> Train Model
+              </Button>
+              <Button variant="outline" className="w-full" disabled={!status?.enabled}>
+                Run Categorization
+              </Button>
+              <p className="text-xs text-slate-400 mt-2">
+                ML runs automatically during statement upload when enabled.
+                Manual training uses all confirmed transactions as labeled data.
+              </p>
+            </CardContent>
+          </Card>
+        </div>
+      )}
+    </div>
+  );
+}
