+"""MACRS depreciation calculation with short tax year support."""
+
+
+def calculate_macrs_depreciation(
+    cost: float,
+    life_years: int,
+    placed_in_month: int = 1,
+    is_short_year: bool = False,
+    short_year_months: int = 12,
+) -> float:
+    """Calculate MACRS depreciation with short tax year support."""
+    if is_short_year and short_year_months < 12:
+        full_year_rate = 1.0 / life_years
+        prorated_rate = full_year_rate * (short_year_months / 12.0)
+        return cost * prorated_rate
+    return cost / life_years
